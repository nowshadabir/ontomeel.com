# --- Security & Credentials ---
# Never track environment variables or secret keys
.env
.env.local
.env.*.local
*.env
config.php
credentials.json

# --- Database & Backups ---
# Ignore database dumps which may contain user data
database/*.sql
/database/ontomeel_bookshop.sql
*.sql
*.gz
*.zip

# --- Uploads & Dynamic Assets ---
# Prevent tracking of user-uploaded images in production
/admin/assets/book-images/*
!/admin/assets/book-images/.gitkeep
/assets/img/preorders/*
!/assets/img/preorders/.gitkeep
/uploads/
/temp/

# --- Logs & Debugging ---
# Ignore PHP error logs and test scripts
error_log
php_errors.log
*.log
/test-email.php
/includes/test_env.php

# --- System & IDE Files ---
# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# IDES
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- PHP/Composer ---
# Ignore dependencies if added later
/vendor/

# --- XAMPP/Live Server ---
# Specific to local development environments
.phpunit.result.cache
.antigravityignore
.htaccess
