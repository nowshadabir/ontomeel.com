# ----------------------------------------------------------------------
# Ontomeel Bookshop - Production .htaccess
# ----------------------------------------------------------------------

# 1. SECURITY: Prevent Directory Browsing
Options -Indexes

# 2. SECURITY: Protect Sensitive Files
<FilesMatch "^\.env|.*\.sql$|.*\.log$|composer\.json|composer\.lock|README\.md">
    Order allow,deny
    Deny from all
</FilesMatch>

# 3. SECURITY: Block access to specific folders
RewriteEngine On
RewriteRule ^(includes|database|admin/assets/book-images/.*\.php) - [F,L]

# 4. HTTPS: Force HTTPS (Standard for Namecheap/cPanel)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 5. CLEAN URLs: Remove .php extension
# Example: ontomeel.com/login works instead of login.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [NC,L]

# 6. PERFORMANCE: Gzip Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# 7. PERFORMANCE: Browser Caching (Expires Headers)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    
    # Images/Icons (Cache for a year)
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    
    # CSS/JS (Cache for a week)
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# 8. ERROR HANDLING: Custom 404 (Optional)
# ErrorDocument 404 /404.php
